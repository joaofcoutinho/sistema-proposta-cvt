# ─── Banco de dados (Neon — Postgres serverless) ───────────────────────────
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# ─── Autenticação (NextAuth v5 / Auth.js) ──────────────────────────────────
# Gere o segredo com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── E-mail transacional (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="propostas@convertido.com.br"
ADMIN_NOTIFICATION_EMAIL="contato@convertido.com.br"

# ─── Armazenamento de arquivos (Vercel Blob) ───────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─── URLs da aplicação ─────────────────────────────────────────────────────
# URL do painel admin
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL pública das propostas (em produção: https://propostas.convertido.com.br)
NEXT_PUBLIC_PUBLIC_URL="http://localhost:3000"

# ─── Seed do primeiro admin (usado por scripts/seed-admin.ts) ──────────────
SEED_ADMIN_EMAIL="marketing@convertido.com.br"
SEED_ADMIN_PASSWORD="troque-esta-senha"
SEED_ADMIN_NAME="Admin Convertido"

# ─── Cron (opcional) ───────────────────────────────────────────────────────
# Se definido, o endpoint /api/cron/expire exige Authorization: Bearer <secret>
CRON_SECRET=""
